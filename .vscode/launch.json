{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Inbound Web (Staging)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "3000"
            ],
            "toolArgs": [
                "--dart-define-from-file=.dart_define.staging.json",
                "--dart-define=FLAVOR=webStaging"
            ]
        },
        {
            "name": "Inbound Web (Production)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "3000"
            ],
            "toolArgs": [
                "--dart-define-from-file=.dart_define.production.json",
                "--dart-define=FLAVOR=webProd"
            ]
        },
        {
            "name": "Inbound Mobile (Staging)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "toolArgs": [
                "--dart-define-from-file=.dart_define.staging.json",
                "--dart-define=FLAVOR=mobileStaging"
            ]
        },
        {
            "name": "Inbound Mobile (Production)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "toolArgs": [
                "--dart-define-from-file=.dart_define.production.json",
                "--dart-define=FLAVOR=mobileProd"
            ]
        }
    ]
}